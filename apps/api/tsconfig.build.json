{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@mauzai/shared": ["packages/shared/dist/index.d.ts"],
      "@mauzai/shared/*": ["packages/shared/dist/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
