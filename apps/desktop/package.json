{
  "name": "@mauzai/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "productName": "MauzAI",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package:mac": "pnpm --filter @mauzai/shared build && pnpm --filter @mauzai/api build && electron-vite build && node scripts/package-macos.mjs",
    "launch:mac": "node scripts/launch-macos.mjs",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@mauzai/api": "workspace:*",
    "@mauzai/shared": "workspace:*",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.1.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitest": "^4.1.6"
  }
}
