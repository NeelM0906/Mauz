{
  "name": "mauzai",
  "version": "0.1.0",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --filter @mauzai/desktop dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "stop:mac": "pnpm --filter @mauzai/desktop stop:mac",
    "install:mac": "pnpm --filter @mauzai/desktop install:mac",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "format:check": "pnpm lint",
    "env:check": "node scripts/check-env.mjs",
    "github:protect-main": "node scripts/configure-main-protection.mjs",
    "security:secrets": "node scripts/check-secrets.mjs",
    "security:audit": "pnpm audit --audit-level moderate",
    "smoke": "pnpm build",
    "check": "pnpm lint && pnpm env:check && pnpm security:secrets && pnpm typecheck && pnpm test && pnpm smoke"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "^7.0.2"
  },
  "pnpm": {
    "overrides": {
      "undici": "7.28.0"
    },
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
